{
  "attribution": {
    "commit": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebFetch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ryansheppard/knowledge/.claude/hooks/session-orient.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ryansheppard/knowledge/.claude/hooks/validate-note.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/ryansheppard/knowledge/.claude/hooks/auto-commit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/ryansheppard/Projects/claude/hooks/check-rules-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ryansheppard/Projects/claude/hooks/check-rules-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-run-commands.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ryansheppard/knowledge/.claude/hooks/session-capture.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cwd=$(cat | jq -r '.cwd'); if git -C \"$cwd\" diff-index --quiet HEAD -- 2>/dev/null; then echo Clean; else echo 'Uncommitted changes'; fi"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "arscontexta@agenticnotetaking": true
  },
  "extraKnownMarketplaces": {
    "agenticnotetaking": {
      "source": {
        "source": "github",
        "repo": "agenticnotetaking/arscontexta"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
